// Texas Dent Company - Prisma Schema
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// NextAuth Models
// =============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  phone           String?
  role            String    @default("CUSTOMER")
  
  // GHL Integration
  ghlContactId    String?   @unique
  partnerId       String?   @unique  // Affiliate/Partner ID
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  accounts        Account[]
  sessions        Session[]
  referrals       Referral[] @relation("PartnerReferrals")
  referredBy      Referral?  @relation("CustomerReferral")
  paymentMethod   PaymentMethod?
  payouts         Payout[]

  @@index([email])
  @@index([ghlContactId])
  @@index([partnerId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================================
// Payment Methods
// =============================================================================

model PaymentMethod {
  id              String   @id @default(cuid())
  userId          String   @unique
  
  // Payment method type: ACH, VENMO, CASHAPP, ZELLE
  type            String
  
  // ACH fields (encrypted in production)
  achAccountNumber    String?
  achRoutingNumber    String?
  achAccountHolder    String?
  
  // Venmo fields
  venmoUsername       String?
  
  // CashApp fields
  cashappCashtag      String?
  
  // Zelle fields
  zelleEmailOrPhone   String?
  
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

// =============================================================================
// Payout Tracking
// =============================================================================

model Payout {
  id              String   @id @default(cuid())
  partnerId       String
  
  amount          Float
  status          String   @default("PENDING")  // PENDING, PROCESSING, COMPLETED, FAILED
  paymentMethod   String   // Type used for this payout
  
  // Transaction details
  transactionId   String?
  notes           String?
  
  // Timing
  requestedAt     DateTime @default(now())
  processedAt     DateTime?
  completedAt     DateTime?
  
  partner         User     @relation(fields: [partnerId], references: [id])

  @@index([partnerId])
  @@index([status])
  @@index([requestedAt])
}

// =============================================================================
// Referral Tracking
// =============================================================================

model Referral {
  id              String   @id @default(cuid())
  partnerId       String
  customerId      String?  @unique
  
  // Customer info (for manual referrals without user account)
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  
  // GHL opportunity tracking
  ghlContactId    String?
  ghlOpportunityId String?
  status          String   @default("NEW_LEAD")
  
  // Opportunity value from GHL
  opportunityValue Float?
  
  // Commission tracking
  commissionRate  Float    @default(0.10)  // 10% default commission
  commissionAmount Float?
  commissionPaid  Boolean  @default(false)
  paidAt          DateTime?
  payoutId        String?
  
  // Source tracking
  source          String?  // Direct Link, Text Message, Social Media, Manual Entry, etc.
  
  // GHL sync metadata
  lastSyncedAt    DateTime?
  syncError       String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  partner         User     @relation("PartnerReferrals", fields: [partnerId], references: [id])
  customer        User?    @relation("CustomerReferral", fields: [customerId], references: [id])

  @@index([partnerId])
  @@index([status])
  @@index([ghlOpportunityId])
  @@index([ghlContactId])
}

// =============================================================================
// GHL Sync Tracking
// =============================================================================

model GHLSyncLog {
  id              String   @id @default(cuid())
  
  syncType        String   // CONTACTS, OPPORTUNITIES, EARNINGS
  status          String   // SUCCESS, PARTIAL, FAILED
  
  recordsProcessed Int     @default(0)
  recordsFailed   Int      @default(0)
  
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  
  errorMessage    String?
  errorDetails    String?  // JSON string with details

  @@index([syncType])
  @@index([startedAt])
}

// =============================================================================
// Contact Form Submissions
// =============================================================================

model ContactSubmission {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String?
  location        String?  // frisco, odessa
  message         String?
  source          String?  // claim-help, quality, home, etc.
  affiliateCode   String?
  
  // GHL sync
  ghlContactId    String?
  syncedToGhl     Boolean  @default(false)
  
  createdAt       DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}
